// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Categoria {
  Medicamento
  Pokebola
  Item_segurar
  Item_batalha
  Miscelaneo
  Evolutivo
  Berry
  TM
  Vitamina
}

enum StatusPedido {
  Pendente
  Entregue
}

// ─── Produto / Marca ──────────────────────────────────────────────────────────

model produto {
  id            Int               @id @default(autoincrement())
  nome          String            @db.VarChar(60)
  descricao     String
  preco         Decimal           @db.Decimal(10, 2)
  categorias    Categoria[]       @default([])
  fotoPrincipal String            @default("")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deleted       Boolean           @default(false)
  marcaId       Int
  marca         marca             @relation(fields: [marcaId], references: [id])
  estoque       Int               @default(10)
  carrinhos     carrinho_produto[]
  pedidos       pedido_produto[]

  @@map("produtos")
}

model marca {
  id    Int       @id @default(autoincrement())
  nome  String    @db.VarChar(60)
  foto  String
  itens produto[]

  @@map("marcas")
}

// ─── Usuário / Auth ───────────────────────────────────────────────────────────

model usuario {
  id              String            @id @default(uuid()) @db.VarChar(36)
  nome            String            @db.VarChar(60)
  email           String            @unique @db.VarChar(255)
  senha           String            @db.VarChar(255)
  imagem          String            @default("https://static.vecteezy.com/system/resources/previews/009/292/244/non_2x/default-avatar-icon-of-social-media-user-vector.jpg")
  createdAt       DateTime          @default(now())
  admin           Boolean           @default(false)
  deleted         Boolean           @default(false)
  tentativasLogin Int               @default(0)
  blocked         Boolean           @default(false)

  resetTokens     tokenResetSenha[]
  sessoes         sessao[]
  carrinhos       carrinho[]
  pedidos         pedido[]
  logs            Log[]

  @@map("usuarios")
}

model tokenResetSenha {
  id        String   @id @default(uuid()) @db.VarChar(36)
  usuarioId String
  token     String   @db.VarChar(255)
  expiracao DateTime
  usado     Boolean  @default(false)
  createdAt DateTime @default(now())

  usuario   usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("tokens_reset_senha")
}

model sessao {
  id           String   @id @default(uuid()) @db.VarChar(36)
  usuarioId    String
  refreshToken String
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  usuario      usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("sessoes")
}

// ─── Carrinho ─────────────────────────────────────────────────────────────────

model carrinho {
  id        Int               @id @default(autoincrement())
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  usuario   usuario           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String
  total     Decimal           @default(0) @db.Decimal(10, 2)
  produtos  carrinho_produto[]

  @@map("carrinhos")
}

model carrinho_produto {
  id         Int      @id @default(autoincrement())
  carrinho   carrinho @relation(fields: [carrinhoId], references: [id], onDelete: Cascade)
  carrinhoId Int
  produto    produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  produtoId  Int
  preco      Decimal  @db.Decimal(10, 2)
  quantidade Int

  @@map("carrinhos_produtos")
}

// ─── Pedidos ──────────────────────────────────────────────────────────────────

model pedido {
  id        Int            @id @default(autoincrement())
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  usuario   usuario        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String
  total     Decimal        @db.Decimal(10, 2)
  status    StatusPedido   @default(Pendente)
  produtos  pedido_produto[]

  @@map("pedidos")
}

model pedido_produto {
  id        Int     @id @default(autoincrement())
  pedido    pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pedidoId  Int
  produto   produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  produtoId Int
  preco     Decimal @db.Decimal(10, 2)
  quantidade Int

  @@map("pedidos_produtos")
}

// ─── Logs ─────────────────────────────────────────────────────────────────────

model Log {
  id          Int      @id @default(autoincrement())
  descricao   String   @db.VarChar(60)
  complemento String   @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  usuario     usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId   String

  @@map("logs")
}
